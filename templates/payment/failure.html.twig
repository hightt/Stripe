{% extends 'base.html.twig' %}

{% block title %}Płatność nie powiodła się{% endblock %}

{% block body %}
<div style="max-width: 600px; margin: 50px auto; padding: 30px; text-align: center; font-family: sans-serif; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
    
    <div style="color: #e53e3e; font-size: 48px; margin-bottom: 20px;">✕</div>
    
    <h1 style="color: #2d3748; margin-bottom: 10px;">Problem z płatnością</h1>
    <p style="color: #718096; line-height: 1.6;">
        Niestety, transakcja dla zamówienia <strong>#{{ order.id }}</strong> została anulowana lub odrzucona przez operatora płatności.
    </p>

    <div style="background-color: #fffaf0; border-left: 4px solid #dd6b20; padding: 15px; text-align: left; margin: 25px 0;">
        <p style="margin: 0; color: #dd6b20; font-size: 14px; line-height: 1.5;">
            Twoje pieniądze nie zostały pobrane. Możesz spróbować opłacić to zamówienie ponownie, wybierając inną metodę płatności lub sprawdzając poprawność danych karty.
        </p>
    </div>

    <div style="margin-top: 30px; display: flex; gap: 15px; justify-content: center;">
        <a href="{{ path('app_order_payment', {'id': order.id}) }}" style="display: inline-block; background-color: #dd6b20; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold;">
            Spróbuj ponownie
        </a>
        <a href="/" style="display: inline-block; background-color: #edf2f7; color: #4a5568; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold;">
            Anuluj
        </a>
    </div>
</div>
{% endblock %}